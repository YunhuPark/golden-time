{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/egen/:path*",
      "destination": "https://apis.data.go.kr/B552657/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/sepsis",
      "destination": "/?triage=RED&disease=%ED%8C%A8%ED%98%88%EC%A6%9D%20(Sepsis)&volume=12997"
    }
  ]
}
